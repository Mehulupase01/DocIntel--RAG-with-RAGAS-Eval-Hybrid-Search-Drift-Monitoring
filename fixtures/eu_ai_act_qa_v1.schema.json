{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["version", "source_doc_sha256", "cases"],
  "properties": {
    "version": {
      "type": "string",
      "enum": ["v0.1", "v1"]
    },
    "source_doc_sha256": {
      "type": "string",
      "minLength": 64
    },
    "cases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "question", "ground_truth", "expected_articles", "category"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "question": { "type": "string", "minLength": 1 },
          "ground_truth": { "type": "string", "minLength": 1 },
          "expected_articles": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "category": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
